# Copy this file to keystore.properties (which is gitignored) and fill in real values.
# Generate an upload keystore with:
#   keytool -genkeypair -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 \
#       -validity 10000 -alias eartranslator
#
# Then enroll in "App Signing by Google Play" so Google holds the app signing key and you
# keep only this upload key.

storeFile=../upload-keystore.jks
storePassword=CHANGE_ME
keyAlias=eartranslator
keyPassword=CHANGE_ME
