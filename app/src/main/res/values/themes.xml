<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.EarTranslator" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand</item>
        <item name="colorPrimaryDark">@color/brand_dark</item>
        <item name="colorOnPrimary">@color/on_brand</item>
        <item name="colorSecondary">@color/person_b</item>
        <!-- Edge-to-edge: keep status bar transparent; insets handled in code. Dark icons
             on the light surface that shows behind the bar. -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
    </style>
</resources>
